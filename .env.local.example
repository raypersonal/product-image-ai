# ========================================
# Product Image AI - 环境变量配置
# ========================================

# ----- 必需 -----

# 阿里云百炼 DashScope API Key（图片生成 + 文本分析）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ----- 可选 -----

# OpenRouter API Key（备用图片生成通道，支持 Flux 等模型）
# 获取地址：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# 火山引擎（即梦AI）Access Key（高美感图片生成）
# 获取地址：https://console.volcengine.com/iam/keymanage
# 注意：需开通视觉智能平台的图片生成服务
VOLC_ACCESS_KEY=your-volc-access-key
VOLC_SECRET_KEY=your-volc-secret-key

# 飞书应用配置（用于从飞书多维表格读取产品数据）
# 获取地址：https://open.feishu.cn/app
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
